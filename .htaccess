RewriteEngine On

# Root path serves the frontend entry file
RewriteRule ^$ index.php [L]

# Existing files/directories should be served directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Any other path goes to the API entry file
RewriteRule ^ api.php [L]